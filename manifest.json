{
  "manifest_version": 3,
  "name": "XOR — Tweet Saver",
  "version": "1.1.0",
  "description": "Production-grade tweet organizer.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": [
        "shared/utils.js",
        "shared/storage.js",
        "content/modules/Extractor.js",
        "content/modules/Popover.js",
        "content/index.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": { "128": "icons/icon128.png" }
  },
  "icons": { "128": "icons/icon128.png" },
  "commands": {
    "save-tweet": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Save the currently hovered tweet"
    }
  }
}
