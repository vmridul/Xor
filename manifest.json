{
  "manifest_version": 3,
  "name": "𝕏𝕠𝕣",
  "version": "2.0.0",
  "description": "Post organizer for 𝕏",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://pbs.twimg.com/*",
    "https://abs.twimg.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https://pbs.twimg.com https://abs.twimg.com data:;"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "public/favicon-16x16.png",
      "32": "public/favicon-32x32.png",
      "192": "public/android-chrome-192x192.png",
      "512": "public/android-chrome-512x512.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ],
  "icons": {
    "16": "public/favicon-16x16.png",
    "32": "public/favicon-32x32.png",
    "192": "public/android-chrome-192x192.png",
    "512": "public/android-chrome-512x512.png"
  },
  "commands": {
    "save-tweet": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Save the currently hovered tweet"
    }
  }
}
